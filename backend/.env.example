FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# ── Garment analysis vision model — pick ONE provider ────────────────
# OPTION A ($0, recommended): Google Gemini free tier
#   Get a key at aistudio.google.com → API keys, then:
#   GEMMA_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   GEMMA_API_KEY=<your AI Studio key>
#   GEMMA_MODEL=gemini-2.5-flash   (check aistudio for the current flash model)
# OPTION B: Fireworks serverless (needs FIREWORKS_API_KEY above)
#   GEMMA_MODEL=accounts/fireworks/models/kimi-k2p6
# OPTION C: self-hosted vLLM (e.g. Gemma 3 on your own GPU)
#   GEMMA_BASE_URL=http://<gpu-host>:8001/v1
#   GEMMA_MODEL=google/gemma-3-27b-it
GEMMA_MODEL=gemini-2.5-flash
GEMMA_BASE_URL=
GEMMA_API_KEY=
# Image-editing model for try-on — flux-kontext-pro or flux-kontext-max
# (flux-1-schnell is text-to-image only and will NOT work for try-on)
FLUX_MODEL=flux-kontext-pro
# IDM-VTON bridge on your AMD MI300X instance (see gpu-server/README.md)
# e.g. http://<AMD_INSTANCE_IP>:9000 — leave empty to use FLUX only
IDM_VTON_URL=
# Public IDM-VTON demo on HuggingFace (free, real try-on, may queue at busy times)
TRYON_HF_SPACE=yisol/IDM-VTON
# Optional: free HF account token (hf.co/settings/tokens) — raises GPU quota
HF_TOKEN=
REDIS_URL=redis://localhost:6379
MAX_IMAGE_SIZE_MB=10

# ── SaaS layer (leave empty for local demo mode) ─────────────────────
# Neon Postgres (free tier) — enables persistence, merchants, telemetry
DATABASE_URL=
# true on hosted deployments (rejects requests without a valid API key)
REQUIRE_API_KEY=false
DEMO_API_KEY=twinfit-demo
# Cloudflare R2 for try-on result images (free 10GB)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
