FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Vision model for garment analysis — must support serverless + image input
# (verified July 2026: Kimi K2.6 does; gemma-3-27b-it does NOT on Fireworks)
GEMMA_MODEL=accounts/fireworks/models/kimi-k2p6
# Image-editing model for try-on — flux-kontext-pro or flux-kontext-max
# (flux-1-schnell is text-to-image only and will NOT work for try-on)
FLUX_MODEL=flux-kontext-pro
REDIS_URL=redis://localhost:6379
MAX_IMAGE_SIZE_MB=10
